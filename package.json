  },
  "devDependencies": {
    "@alloy-js/cli": "0.22.0",
    "@alloy-js/rollup-plugin": "0.1.0",
    "@azure-tools/typespec-azure-core": "^0.65.0",
    "@azure-tools/typespec-azure-resource-manager": "^0.65.0",
    "@azure-tools/typespec-client-generator-core": "^0.65.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.1.0",
    "@typespec/compiler": "^1.9.0",
    "@typespec/http": "^1.9.0",
