    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "web-tree-sitter": "^0.26.5"
  },
  "scripts": {
    "build": "alloy build",
    "clean": "rimraf dist/ .temp/",
    "ralph": "node ralph.js --iterations 50",
    "test": "vitest run",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:e2e": "pnpm emit:e2e && vitest run --config vitest.config.e2e.ts",
    "emit:e2e": "npx tsx eng/scripts/emit-e2e.ts",
    "test:watch": "vitest -w",
    "watch": "alloy build --watch",
    "lint": "eslint src/ test/ --report-unused-disable-directives --max-warnings=0",
    "lint:fix": "eslint . --report-unused-disable-directives --fix",
    "format": "prettier .  --write",
    "format:check": "prettier --check .",
    "test:e2e:ci": "pnpm build && pnpm test:e2e",
    "coverage": "npx tsx eng/scripts/calculate-coverage.ts",
    "ci": "pnpm build && vitest run && pnpm test:smoke && pnpm test:e2e"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./stc": {
      "import": "./dist/src/stc.js",
      "types": "./dist/src/stc.d.ts"
    },
    "./testing": {
      "types": "./dist/src/testing/index.d.ts",
      "default": "./dist/src/testing/index.js"
    }
  }
}
